# ─────────────────────────────────────────────────────────────
# Zero Hunger — Backend environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB connection string (MongoDB Atlas or self-hosted)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/zero-hunger

# JWT signing secret — MUST be a strong random string (>= 32 chars).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-chars

# SMTP / Gmail (use a Gmail App Password, not your account password)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-gmail-app-password

# Public URL of the frontend (used for CORS + password-reset links)
FRONTEND_URL=http://localhost:5173

# ImgBB API key for image uploads — https://api.imgbb.com/
IMGBB_KEY=your-imgbb-api-key
